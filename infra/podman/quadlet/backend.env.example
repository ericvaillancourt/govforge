# GovForge backend — runtime env (template).
#
# Copy to `backend.env` next to this file (gitignored), fill in the
# real values, then place on the hypervisor at:
#   /home/eric/govforge/backend/backend.env
# The quadlet at govforge-backend.container reads it via EnvironmentFile.

# ---- Database --------------------------------------------------------
# Either a SQLite path (no scheme — wrapped in sqlite:///) or a full URL.
# For PostgreSQL use psycopg 3:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
GOVFORGE_DB=postgresql+psycopg://CHANGEME_USER:CHANGEME_PASSWORD@CHANGEME_HOST:5432/govforge

# ---- API bind --------------------------------------------------------
GOVFORGE_API_HOST=0.0.0.0
GOVFORGE_API_PORT=8787

# ---- Schema bootstrap -----------------------------------------------
# 1 = create_all on startup if the core tables are missing (Phase 1).
# Once Alembic lands, set to 0 and run migrations explicitly.
GOVFORGE_BOOTSTRAP_SCHEMA=1
