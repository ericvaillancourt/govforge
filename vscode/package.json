{
  "name": "govforge",
  "displayName": "GovForge",
  "description": "Local-first governance for AI coding agents — tasks, decisions, reviews, approvals in your sidebar.",
  "version": "0.1.0",
  "publisher": "ericvaillancourt",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericvaillancourt/govforge.git",
    "directory": "vscode"
  },
  "homepage": "https://govforge.dev",
  "bugs": {
    "url": "https://github.com/ericvaillancourt/govforge/issues"
  },
  "keywords": [
    "ai-governance",
    "mcp",
    "claude-code",
    "codex",
    "audit-trail",
    "review",
    "cockpit"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "govforge",
          "title": "GovForge",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "govforge": [
        {
          "id": "govforge.tasks",
          "name": "Tasks"
        },
        {
          "id": "govforge.decisions",
          "name": "Decisions"
        },
        {
          "id": "govforge.reviews",
          "name": "Reviews"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "govforge.tasks",
        "contents": "Choose where to connect first, then sign in.\n[Switch backend](command:govforge.switchBackend)\n[Sign in](command:govforge.signIn)\n[Refresh](command:govforge.refresh)",
        "when": "!govforge.signedIn"
      },
      {
        "view": "govforge.tasks",
        "contents": "No project selected. Pick one to populate the trees.\n[Switch project](command:govforge.switchProject)\n[Refresh](command:govforge.refresh)",
        "when": "govforge.signedIn"
      },
      {
        "view": "govforge.decisions",
        "contents": "No project selected.\n[Switch project](command:govforge.switchProject)",
        "when": "govforge.signedIn"
      },
      {
        "view": "govforge.reviews",
        "contents": "No project selected.\n[Switch project](command:govforge.switchProject)",
        "when": "govforge.signedIn"
      }
    ],
    "commands": [
      {
        "command": "govforge.signIn",
        "title": "GovForge: Sign In",
        "icon": "$(sign-in)"
      },
      {
        "command": "govforge.signOut",
        "title": "GovForge: Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "govforge.refresh",
        "title": "GovForge: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "govforge.switchBackend",
        "title": "GovForge: Switch Backend",
        "icon": "$(plug)"
      },
      {
        "command": "govforge.switchProject",
        "title": "GovForge: Switch Project",
        "icon": "$(folder)"
      },
      {
        "command": "govforge.registerProject",
        "title": "GovForge: Register Workspace as Project"
      },
      {
        "command": "govforge.openDecision",
        "title": "GovForge: Open Decision Detail"
      },
      {
        "command": "govforge.createTask",
        "title": "GovForge: Create Task",
        "icon": "$(add)"
      },
      {
        "command": "govforge.recordDecision",
        "title": "GovForge: Record Decision",
        "icon": "$(note)"
      },
      {
        "command": "govforge.attachGitDiff",
        "title": "GovForge: Attach Git Diff",
        "icon": "$(git-commit)"
      },
      {
        "command": "govforge.runPolicyChecks",
        "title": "GovForge: Run Policy Checks",
        "icon": "$(checklist)"
      },
      {
        "command": "govforge.requestReview",
        "title": "GovForge: Request Review",
        "icon": "$(eye)"
      },
      {
        "command": "govforge.submitReview",
        "title": "GovForge: Submit Review",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "govforge.approve",
        "title": "GovForge: Approve Decision",
        "icon": "$(check)"
      },
      {
        "command": "govforge.reject",
        "title": "GovForge: Reject Decision",
        "icon": "$(x)"
      },
      {
        "command": "govforge.recordDisagreement",
        "title": "GovForge: Record Disagreement",
        "icon": "$(warning)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "govforge.createTask",
          "when": "view == govforge.tasks",
          "group": "navigation@0"
        },
        {
          "command": "govforge.switchProject",
          "when": "view == govforge.tasks || view == govforge.decisions || view == govforge.reviews",
          "group": "navigation@1"
        },
        {
          "command": "govforge.refresh",
          "when": "view == govforge.tasks || view == govforge.decisions || view == govforge.reviews",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "govforge.recordDecision",
          "when": "view == govforge.tasks && viewItem == govforge.task",
          "group": "1_actions@1"
        },
        {
          "command": "govforge.attachGitDiff",
          "when": "view == govforge.decisions && viewItem == govforge.decision",
          "group": "1_actions@1"
        },
        {
          "command": "govforge.runPolicyChecks",
          "when": "view == govforge.decisions && viewItem == govforge.decision",
          "group": "1_actions@2"
        },
        {
          "command": "govforge.requestReview",
          "when": "view == govforge.decisions && viewItem == govforge.decision",
          "group": "2_review@1"
        },
        {
          "command": "govforge.recordDisagreement",
          "when": "view == govforge.decisions && viewItem == govforge.decision",
          "group": "2_review@2"
        },
        {
          "command": "govforge.approve",
          "when": "view == govforge.decisions && viewItem == govforge.decision",
          "group": "3_approve@1"
        },
        {
          "command": "govforge.reject",
          "when": "view == govforge.decisions && viewItem == govforge.decision",
          "group": "3_approve@2"
        },
        {
          "command": "govforge.submitReview",
          "when": "view == govforge.reviews && viewItem == govforge.review",
          "group": "1_actions@1"
        }
      ],
      "commandPalette": [
        {
          "command": "govforge.openDecision",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "GovForge",
      "properties": {
        "govforge.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8787",
          "description": "Base URL of the GovForge HTTP API. Use http://127.0.0.1:8787 for a local backend started with `gf api serve`, or https://api.govforge.dev for the hosted backend."
        },
        "govforge.agent": {
          "type": "string",
          "default": "",
          "description": "Agent name credited on author actions (create task, record decision, attach git, run policy). Leave empty to use the OS user. Set to 'claude' / 'codex' / etc. to drive these from an automation."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && tsc -p ./tsconfig.webview.json && npm run bundle:extension && npm run bundle:webview",
    "bundle:extension": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --outfile=out/extension.js",
    "bundle:webview": "esbuild webview/index.tsx --bundle --platform=browser --target=es2022 --format=iife --minify --define:process.env.NODE_ENV='\"production\"' --outfile=out/webview.js",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --outfile=out/extension.js --watch=forever",
    "lint": "tsc --noEmit && tsc -p ./tsconfig.webview.json --noEmit",
    "package": "vsce package",
    "gen-types": "openapi-typescript http://127.0.0.1:8787/openapi.json -o src/api/types.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "marked": "^14.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
